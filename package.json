{
	"name": "des-team-porfolio",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"imgYmlCreator": "bun src/lib/utils/imgYmlCreator.ts",
		"sync-media": "bun scripts/sync-media-folders.js",
		"dither": "bun src/lib/utils/buildDither.ts",
		"dither:check": "bun src/lib/utils/validateDither.ts",
		"dither:all": "bun run dither && bun run dither:check",
		"build": "PATH=\"$HOME/.bun/bin:$PATH\" bun run dither:all && vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"lint": "prettier --check .",
		"deploy": "bun run build"
	},
	"browserslist": [
		"last 1 Chrome version",
		"last 1 Edge version",
		"last 1 Firefox version",
		"last 1 Safari version",
		"last 1 iOS major version",
		"not dead"
	],
	"devDependencies": {
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/enhanced-img": "^0.8.5",
		"@sveltejs/kit": "^2.22.0",
		"@sveltejs/vite-plugin-svelte": "^6.0.0",
		"@tailwindcss/vite": "^4.2.1",
		"@types/bun": "^1.2.22",
		"@types/node": "^25.3.3",
		"prettier": "^3.4.2",
		"prettier-plugin-svelte": "^3.3.3",
		"svelte": "^5.0.0",
		"svelte-check": "^4.0.0",
		"tailwindcss": "^4.2.1",
		"typescript": "^5.0.0",
		"vite": "^7.0.4",
		"vite-imagetools": "^8.0.0"
	},
	"dependencies": {
		"@thi.ng/pixel-dither": "^1.1.191",
		"js-yaml": "^4.1.0",
		"sharp": "^0.34.5",
		"svelte-inview": "^4.0.4",
		"svelte-pdf": "github:TommasoPrinetti/svelte-pdf",
		"sveltekit-device-detector": "^2.0.1",
		"yaml": "^2.8.1"
	},
	"optionalDependencies": {
		"@rollup/rollup-linux-arm64-gnu": "^4.0.0"
	}
}
